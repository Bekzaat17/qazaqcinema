# ============================================================================
# QazaqCinema — ТЕСТОВАЯ конфигурация (коммитится, секретов нет).
# Читается ./start.sh test: ruff+mypy+pytest гоняются В КОНТЕЙНЕРЕ (образ-стадия test).
# Ключевое: DB_NAME=qazaqcinema_test — тесты идут в ИЗОЛИРОВАННУЮ БД, рабочую не трогают
# (чора «изоляция БД тестов», PLAN.md). DB_HOST/REDIS_HOST — имена сервисов compose.
# ============================================================================
BOT_TOKEN=test:token
BOT_ADMIN_CHAT_ID=0
BOT_ADMIN_USER_IDS=1
BOT_ARCHIVE_CHANNEL_ID=-1000000000000
BOT_WEBAPP_URL=http://localhost

DB_HOST=postgres
DB_PORT=5432
DB_USER=qazaqcinema
DB_PASSWORD=qazaqcinema
DB_NAME=qazaqcinema_test

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1

PAY_KASPI_NUMBER=+7 700 000 00 00
PAY_KASPI_NAME=Test

API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*
