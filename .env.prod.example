# ============================================================================
# QazaqCinema — ПРОД. Шаблон. Скопируй и заполни РЕАЛЬНЫМИ значениями:
#   cp .env.prod.example .env.prod
# Читается ./start.sh prod. Файл .env.prod в git НЕ коммитится (секреты!).
# DB_HOST/REDIS_HOST внутри compose всё равно перекрываются на postgres/redis.
# ============================================================================

# --- Публичный адрес (ОДИН источник правды) ----------------------------------
# Из PUBLIC_ORIGIN выводятся: site address Caddy (авто-TLS), CORS, URL Mini App,
# режим бота. Пиши СО СХЕМОЙ https:// — это и есть флаг прода (https ⟹ webhook +
# Caddy сам выпускает и продлевает TLS-сертификат Let's Encrypt, без certbot/cron).
PUBLIC_ORIGIN=https://qazaqcinema.rehubpro.kz
ACME_EMAIL=you@example.com                     # ← твой реальный e-mail для Let's Encrypt

# --- Бот ---------------------------------------------------------------------
BOT_TOKEN=                                     # прод-токен от @BotFather
BOT_ADMIN_CHAT_ID=-1001234567890               # чат модерации (куда падают чеки)
BOT_ADMIN_USER_IDS=11111111,22222222           # админы через запятую
BOT_ARCHIVE_CHANNEL_ID=-1009876543210          # секретный канал-архив с видео
# BOT_WEBAPP_URL/BOT_WEBHOOK_URL выводятся из PUBLIC_ORIGIN — тут НЕ задаём.

# Вебхук (прод): путь + секрет. Режим webhook включается схемой https в PUBLIC_ORIGIN.
BOT_WEBHOOK_PATH=/tg/webhook                   # Caddy проксирует /tg/ → bot:8080
BOT_WEBHOOK_SECRET=GENERATE_ME                  # секрет-токен: openssl rand -hex 32
# Аварийный обход: =1 форсит polling, если хостер/транзит режет входящий webhook от
# Telegram (getWebhookInfo → "Connection timed out"). Web App/CORS остаются на https.
# Подробно — DEPLOY.md §4. По умолчанию 0 (webhook по схеме PUBLIC_ORIGIN).
BOT_FORCE_POLLING=0

# --- PostgreSQL --------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=qazaqcinema
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD          # ← смени на сильный пароль
DB_NAME=qazaqcinema

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Оплата ------------------------------------------------------------------
# Kaspi: способ включается ЗАПОЛНЕННОСТЬЮ. Заданы оба (номер+ссылка) → доступны оба;
# только номер → только перевод по номеру; только ссылка → только оплата по ссылке.
PAY_KASPI_NUMBER=+7 700 000 00 00              # перевод по номеру (пусто → способ скрыт)
PAY_KASPI_NAME=Иван И.                          # имя получателя (рядом с номером)
PAY_KASPI_LINK=                                # оплата по ссылке Kaspi Pay (пусто → способ скрыт)

# --- API ---------------------------------------------------------------------
# API_CORS_ORIGINS больше НЕ задаётся — CORS = PUBLIC_ORIGIN (в проде всё равно same-origin за Caddy).
API_HOST=0.0.0.0
API_PORT=8000

# --- Медиа -------------------------------------------------------------------
MEDIA_ROOT=uploads
MEDIA_POSTERS_URL_BASE=/posters
