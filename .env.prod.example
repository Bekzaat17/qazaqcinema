# ============================================================================
# QazaqCinema — ПРОД. Шаблон. Скопируй и заполни РЕАЛЬНЫМИ значениями:
#   cp .env.prod.example .env.prod
# Читается ./start.sh prod. Файл .env.prod в git НЕ коммитится (секреты!).
# DB_HOST/REDIS_HOST внутри compose всё равно перекрываются на postgres/redis.
# ============================================================================

# --- Бот ---------------------------------------------------------------------
BOT_TOKEN=                                     # прод-токен от @BotFather
BOT_ADMIN_CHAT_ID=-1001234567890               # чат модерации (куда падают чеки)
BOT_ADMIN_USER_IDS=11111111,22222222           # админы через запятую
BOT_ARCHIVE_CHANNEL_ID=-1009876543210          # секретный канал-архив с видео
BOT_WEBAPP_URL=https://your-domain.example/    # URL Web App (при домене — https)

# Вебхук (прод): бот слушает webhook вместо polling. Пусто → polling (dev).
BOT_WEBHOOK_URL=https://your-domain.example    # тот же домен (без пути); пусто → polling
BOT_WEBHOOK_PATH=/tg/webhook                   # Nginx проксирует /tg/ → bot:8080
BOT_WEBHOOK_SECRET=GENERATE_ME                  # секрет-токен: openssl rand -hex 32

# --- PostgreSQL --------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=qazaqcinema
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD          # ← смени на сильный пароль
DB_NAME=qazaqcinema

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Оплата ------------------------------------------------------------------
PAY_KASPI_NUMBER=+7 700 000 00 00              # номер Kaspi для перевода
PAY_KASPI_NAME=Иван И.                          # имя получателя (видно на пэйволле)
PAY_KASPI_LINK=                                # ссылка Kaspi Pay (pay.kaspi.kz/pay/...)

# --- API ---------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=https://your-domain.example   # домен Web App (в проде всё равно same-origin за nginx)

# --- Web / TLS (nginx) -------------------------------------------------------
# WEB_TLS=true → nginx на :443 (нужен сертификат Let's Encrypt, см. DEPLOY.md). Пока сертификата
# нет, nginx автоматически поднимается на :80 и обслуживает ACME-челлендж (безопасный фолбэк).
WEB_TLS=true
WEB_SERVER_NAME=your-domain.example            # домен (server_name + путь к сертификату)

# --- Медиа -------------------------------------------------------------------
MEDIA_ROOT=uploads
MEDIA_POSTERS_URL_BASE=/posters
