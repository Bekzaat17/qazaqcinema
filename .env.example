# ============================================================================
# QazaqCinema — пример конфигурации. Скопируй в .env и заполни.
#   cp .env.example .env
# Каждая секция читается своим префиксом (BOT_, DB_, REDIS_, PAY_, API_, MEDIA_).
# ============================================================================

# --- Бот ---------------------------------------------------------------------
BOT_TOKEN=123456:ABC-DEF...                  # токен от @BotFather
BOT_ADMIN_CHAT_ID=-1001234567890             # чат модерации (куда падают чеки)
BOT_ADMIN_USER_IDS=11111111,22222222         # админы (DM-подтверждения), через запятую
BOT_ARCHIVE_CHANNEL_ID=-1009876543210        # секретный канал-архив с видео
BOT_WEBAPP_URL=https://example.com/app       # URL Web App (кнопка 🍿)

# --- PostgreSQL --------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=qazaqcinema
DB_PASSWORD=qazaqcinema
DB_NAME=qazaqcinema

# --- Redis (задел: кеш каталога/кулдауны) ------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Оплата ------------------------------------------------------------------
PAY_KASPI_NUMBER=+7 700 000 00 00            # номер Kaspi для перевода
PAY_KASPI_NAME=Иван И.                        # имя получателя (отображается на пэйволле)

# --- API ---------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*                            # через запятую; в проде — домен Web App

# --- Медиа (постеры на VPS) --------------------------------------------------
MEDIA_ROOT=uploads                           # каталог на диске (постеры → uploads/posters)
MEDIA_POSTERS_URL_BASE=/posters              # публичный префикс URL постера (StaticFiles + БД)
